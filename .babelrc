{
  "presets": [
    "next/babel"
  ],
  "plugins": [
    [
      "styled-components",
      {
        "ssr": true
      }
    ],
    [
      "module-resolver",
      {
        "root": [
          "./src"
        ],
        "alias": {
          "core": "./src/core",
          "ui": "./src/ui"
        }
      },
      "@babel/plugin-transform-runtime"
    ]
  ]
}
